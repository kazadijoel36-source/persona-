# Copy this to .env and fill in real values. Never commit the real .env.

DATABASE_URL=sqlite:///./personaos.db

# Long random string — used to sign session JWTs. Rotate this and every
# active session is invalidated, which is the correct behavior if it leaks.
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_HOURS=720

# false for local http dev, true once served over https
COOKIE_SECURE=false

# Comma-separated list. Must be explicit origins (not "*") because
# allow_credentials=True is required for the cookie-based session to work.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# From your Lemon Squeezy store's webhook settings. Leave unset locally and
# the webhook route will simply refuse all payloads rather than trust them.
LEMON_SQUEEZY_WEBHOOK_SECRET=replace-with-webhook-secret

# Set to "production" to disable the /billing/dev/upgrade convenience route.
ENV=development
